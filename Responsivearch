<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>HOP ON ROSA – Developer &amp; DevOps Guide</title>
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0
    }

    :root {
      --navy: #0A1628;
      --slate: #1E293B;
      --slate2: #334155;
      --muted: #64748B;
      --border: #E2E8F0;
      --bg: #F8FAFC;
      --card: #FFFFFF;
      --code: #0F172A;
      --blue: #1E5BDE;
      --teal: #0EA5B0;
      --green: #10B981;
      --amber: #F59E0B;
      --red: #EF4444;
      --purple: #8B5CF6;
      --hop: #FF6D00;
      --px: clamp(16px, 5vw, 72px);
      --gap: clamp(14px, 2vw, 24px);
      --r: 12px;
    }

    html {
      scroll-behavior: smooth
    }

    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: var(--bg);
      color: var(--slate);
      font-size: clamp(14px, 1.5vw, 16px);
      line-height: 1.6;
      display: flex;
      height: 100vh;
      overflow: hidden
    }

    .nav {
      width: clamp(220px, 18vw, 280px);
      flex-shrink: 0;
      height: 100vh;
      overflow-y: auto;
      background: var(--bg);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column
    }

    .main-content {
      flex: 1;
      height: 100vh;
      overflow-y: auto;
      scroll-behavior: smooth;
      position: relative
    }

    .nav-inner {
      display: flex;
      flex-direction: column;
      padding: 24px 0
    }

    .nav-logo {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 0 24px 24px;
      border-bottom: 1px solid var(--border);
      margin-bottom: 16px
    }

    .hop-dot {
      width: 24px;
      height: 24px;
      background: var(--hop);
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 10px;
      font-weight: 900;
      color: #fff;
      flex-shrink: 0
    }

    .nav-title {
      font-size: 12px;
      font-weight: 700;
      color: var(--slate);
      letter-spacing: .5px;
      text-transform: uppercase;
      line-height: 1.4
    }

    .nav-links {
      display: flex;
      flex-direction: column
    }

    .nl {
      font-size: 13px;
      font-weight: 600;
      color: var(--muted);
      text-decoration: none;
      padding: 10px 24px;
      display: flex;
      align-items: center;
      transition: all .15s;
      border-left: 3px solid transparent
    }

    .nl:hover,
    .nl.active {
      color: var(--blue);
      background: rgba(30, 91, 222, .05);
      border-left-color: var(--teal)
    }

    .hero {
      background: linear-gradient(135deg, #EFF6FF 0%, #DBEAFE 100%);
      padding: clamp(24px, 4vw, 40px) var(--px) clamp(24px, 4vw, 32px);
      position: relative;
      overflow: hidden
    }

    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 80% 60% at 70% 20%, rgba(30, 91, 222, .08), transparent)
    }

    .hero-ey {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--teal);
      margin-bottom: 14px
    }


    .hero-sub {
      font-size: clamp(13px, 1.4vw, 15px);
      color: var(--slate2);
      max-width: 660px;
      line-height: 1.6;
      margin-bottom: 20px
    }


    .journey {
      background: var(--card);
      overflow-x: auto;
      scrollbar-width: none;
      border-bottom: 1px solid var(--border)
    }

    .journey::-webkit-scrollbar {
      display: none
    }

    .j-inner {
      display: flex;
      align-items: stretch;
      min-width: max-content
    }

    .j-step {
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 2px;
      padding: 14px clamp(14px, 2vw, 26px);
      border-right: 1px solid var(--border);
      text-decoration: none;
      transition: background .15s
    }

    .j-step:hover {
      background: rgba(30, 91, 222, .04)
    }

    .j-step:last-child {
      border-right: none
    }

    .j-num {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--teal)
    }

    .j-name {
      font-size: 12px;
      font-weight: 600;
      color: var(--slate2);
      white-space: nowrap
    }

    .section {
      padding: clamp(24px, 4vw, 40px) var(--px) 0
    }

    .section:last-of-type {
      padding-bottom: clamp(40px, 6vw, 60px)
    }

    .sec-lbl {
      font-size: 14px;
      font-weight: 600;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: var(--teal);
      margin-bottom: 8px
    }

    .sec-h {
      font-size: clamp(16px, 3.1vw, 20px);
      font-weight: 600;
      color: var(--slate);
      letter-spacing: -1px;
      line-height: 1.15;
      margin-bottom: 8px
    }

    .sec-sub {
      font-size: clamp(14px, 1.4vw, 16px);
      color: var(--muted);
      max-width: 620px;
      line-height: 1.6;
      margin-bottom: clamp(22px, 3vw, 36px)
    }

    .divider {
      height: 1px;
      background: var(--border);
      margin-bottom: clamp(22px, 3vw, 36px)
    }

    .flow-bar {
      display: flex;
      align-items: center;
      gap: 0;
      overflow-x: auto;
      padding: 22px 24px;
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--r);
      margin-bottom: var(--gap);
      scrollbar-width: none
    }

    .flow-bar::-webkit-scrollbar {
      display: none
    }

    .fn {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 5px;
      flex: 1;
      min-width: 80px;
      padding: 0 6px;
      text-align: center
    }

    .fi {
      width: 50px;
      height: 50px;
      border-radius: 11px;
      display: flex;
      align-items: center;
      justify-content: center
    }

    .fi img,
    .fi svg {
      width: 30px;
      height: 30px;
      object-fit: contain
    }

    .fi-hop {
      width: 30px;
      height: 30px;
      background: var(--hop);
      border-radius: 7px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 11px;
      font-weight: 900;
      color: #fff
    }

    .fl {
      font-size: 11px;
      font-weight: 700;
      color: var(--slate)
    }

    .fs {
      font-size: 10px;
      color: var(--muted)
    }

    .fa {
      color: #CBD5E1;
      font-size: 20px;
      flex-shrink: 0;
      margin-bottom: 22px
    }

    .layers {
      display: flex;
      flex-direction: row;
      gap: var(--gap);
      margin-bottom: var(--gap);
      position: relative;
      align-items: stretch;
    }

    @media(max-width: 900px) {
      .layers {
        flex-direction: column;
      }
    }

    .layer {
      flex: 1;
      display: flex;
      flex-direction: column;
      border-radius: var(--r);
      padding: 18px 22px;
      position: relative;
      transition: transform .2s, box-shadow .2s
    }

    .layer::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 4px;
      border-radius: var(--r) 0 0 var(--r)
    }

    .l-badge {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      margin-bottom: 8px;
      display: flex;
      align-items: center;
      gap: 6px
    }

    .l-badge::before {
      font-size: 12px;
      font-weight: 600
    }

    .l-title {
      font-size: 16px;
      font-weight: 700;
      margin-bottom: 4px
    }

    .l-sub {
      font-size: 13px;
      opacity: .82;
      line-height: 1.5
    }

    .l-detail {
      margin-top: 14px;
      font-size: 12px;
      opacity: .85;
      display: flex;
      flex-direction: column;
      gap: 5px;
    }

    .l-detail span {
      display: flex;
      align-items: flex-start;
    }

    .l-detail span::before {
      content: '•';
      margin-right: 8px;
      font-weight: bold;
      opacity: .8;
    }

    .ly1 {
      background: #EFF6FF;
      border: 1px solid #BFDBFE;
      box-shadow: 0 2px 8px rgba(30, 91, 222, .08)
    }

    .ly1::before {
      background: #1E5BDE
    }

    .ly1 .l-badge {
      color: #0369A1;
      font-size: 10px
    }

    .ly1 .l-badge::before {
      content: '①'
    }

    .ly1 .l-title {
      color: #1E3A8A
    }

    .ly1 .l-sub,
    .ly1 .l-detail {
      color: #1E40AF
    }

    .ly2 {
      background: #F0FDF4;
      border: 1px solid #BBF7D0;
      box-shadow: 0 2px 8px rgba(16, 185, 129, .08)
    }

    .ly2::before {
      background: #10B981
    }

    .ly2 .l-badge {
      color: #047857;
      font-size: 10px
    }

    .ly2 .l-badge::before {
      content: '②'
    }

    .ly2 .l-title {
      color: #14532D
    }

    .ly2 .l-sub,
    .ly2 .l-detail {
      color: #15803D
    }

    .ly3 {
      background: #F5F3FF;
      border: 1px solid #DDD6FE;
      box-shadow: 0 2px 8px rgba(139, 92, 246, .08)
    }

    .ly3::before {
      background: #8B5CF6
    }

    .ly3 .l-badge {
      color: #7c3aed;
      font-size: 10px
    }

    .ly3 .l-badge::before {
      content: '③'
    }

    .ly3 .l-title {
      color: #4C1D95
    }

    .ly3 .l-sub,
    .ly3 .l-detail {
      color: #6B21A8
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: var(--gap);
      margin-bottom: var(--gap)
    }

    @media(max-width:760px) {
      .grid {
        grid-template-columns: 1fr
      }
    }

    .full {
      grid-column: 1/-1
    }

    .fc {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--r);
      overflow: hidden
    }

    .fc-hd {
      padding: 14px 20px;
      display: flex;
      align-items: center;
      gap: 12px;
      border-bottom: 1px solid var(--border)
    }

    .fc-icon {
      width: 34px;
      height: 34px;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0
    }

    .fc-icon img,
    .fc-icon svg {
      width: 19px;
      height: 19px;
      object-fit: contain
    }

    .fc-hop {
      width: 19px;
      height: 19px;
      background: var(--hop);
      border-radius: 4px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 8px;
      font-weight: 900;
      color: #fff
    }

    .fc-fn {
      font-family: 'JetBrains Mono', monospace;
      font-size: 13px;
      font-weight: 600;
      color: var(--slate)
    }

    .fc-tag {
      font-size: 11px;
      color: var(--muted);
      margin-top: 1px
    }

    .fc-bd {
      padding: 16px 20px;
      display: flex;
      flex-direction: column;
      gap: 11px
    }

    .fc-what {
      font-size: 13px;
      color: var(--slate2);
      line-height: 1.5
    }

    .rule {
      display: flex;
      align-items: flex-start;
      gap: 8px;
      font-size: 12.5px;
      color: var(--slate2);
      line-height: 1.4
    }

    .rd {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      flex-shrink: 0;
      margin-top: 5px
    }

    .yes .rd {
      background: var(--green)
    }

    .yes {
      color: var(--slate2)
    }

    .no .rd {
      background: var(--red)
    }

    .no {
      color: var(--slate2)
    }

    .cw {
      border-radius: 10px;
      overflow: hidden;
      border: 1px solid var(--border)
    }

    details summary {
      cursor: pointer;
      list-style: none;
      outline: none;
    }

    details summary::-webkit-details-marker {
      display: none;
    }

    .view-code-btn {
      margin-left: auto;
      font-size: 11px;
      font-weight: 700;
      color: var(--blue);
      background: #EFF6FF;
      padding: 6px 12px;
      border-radius: 6px;
      transition: all 0.15s;
    }

    details[open] .view-code-btn {
      background: #F1F5F9;
      color: var(--slate2);
    }


    pre {
      background: #F8FAFC;
      padding: 16px 20px;
      font-family: 'JetBrains Mono', monospace;
      font-size: clamp(10.5px, 1.1vw, 12px);
      line-height: 1.4;
      overflow-x: auto;
      margin: 0;
      color: var(--slate)
    }

    .kw {
      color: #0284C7
    }

    .val {
      color: #16A34A
    }

    .str {
      color: #DC2626
    }

    .cmt {
      color: #94A3B8;
      font-style: italic
    }

    .cmd {
      color: #DB2777;
      font-weight: 600
    }

    .arg {
      color: #475569
    }

    .key {
      color: #9333EA
    }

    .punct {
      color: #64748B
    }

    .note {
      border-radius: 9px;
      padding: 12px 15px
    }

    .n-lbl {
      font-size: 9.5px;
      font-weight: 700;
      letter-spacing: 1px;
      text-transform: uppercase;
      margin-bottom: 4px
    }

    .n-txt {
      font-size: 12.5px;
      line-height: 1.5
    }

    .n-blue {
      background: #EFF6FF;
      border: 1px solid #BFDBFE
    }

    .n-blue .n-lbl {
      color: #0369A1
    }

    .n-blue .n-txt {
      color: #0C4A6E
    }

    .n-green {
      background: #F0FDF4;
      border: 1px solid #BBF7D0
    }

    .n-green .n-lbl {
      color: #15803D
    }

    .n-green .n-txt {
      color: #14532D
    }

    .n-amber {
      background: #FFFBEB;
      border: 1px solid #FDE68A
    }

    .n-amber .n-lbl {
      color: #B45309
    }

    .n-amber .n-txt {
      color: #78350F
    }

    .n-red {
      background: #FEF2F2;
      border: 1px solid #FCA5A5
    }

    .n-red .n-lbl {
      color: #B91C1C
    }

    .n-red .n-txt {
      color: #7F1D1D
    }

    .n-navy {
      background: #071428;
      border: 1px solid #1A3560
    }

    .n-navy .n-lbl {
      color: #7EB6FF
    }

    .n-navy .n-txt {
      color: #93BFEF
    }

    .gates {
      display: flex;
      gap: 0;
      border: 1px solid var(--border);
      border-radius: var(--r);
      overflow: hidden;
      margin-bottom: var(--gap)
    }

    .gate {
      flex: 1;
      padding: 14px 10px;
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
      text-align: center
    }

    .gate:last-child {
      border-right: none
    }

    .gc {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      font-size: 12px;
      font-weight: 800;
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 3px
    }

    .gn {
      font-size: 12px;
      font-weight: 700;
      color: var(--slate)
    }

    .gt {
      font-size: 10px;
      color: var(--muted)
    }

    .garr {
      color: #CBD5E1;
      font-size: 18px;
      margin-bottom: 28px
    }

    @media(max-width:560px) {
      .gates {
        flex-direction: column
      }

      .gate {
        border-right: none;
        border-bottom: 1px solid var(--border);
        flex-direction: row;
        text-align: left;
        gap: 12px
      }

      .gate:last-child {
        border-bottom: none
      }

      .garr {
        display: none
      }
    }

    .dyna-card {
      background: #FFFFFF;
      border: 1px solid var(--border);
      border-radius: var(--r);
      overflow: hidden;
      margin-bottom: var(--gap)
    }

    .dyna-hd {
      background: #F8FAFC;
      padding: 16px 22px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap
    }

    .dyna-ic {
      width: 36px;
      height: 36px;
      border-radius: 8px;
      background: rgba(31, 111, 235, .18);
      border: 1px solid rgba(31, 111, 235, .3);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0
    }

    .dyna-ic img {
      width: 20px;
      height: 20px;
      object-fit: contain
    }

    .dyna-ht {
      font-size: 13px;
      font-weight: 700;
      color: var(--slate);
      text-transform: uppercase;
      letter-spacing: .3px
    }

    .dyna-hs {
      font-size: 12px;
      color: var(--slate2);
      margin-top: 2px
    }

    .dyna-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
      padding: 16px 22px
    }

    @media(max-width:560px) {
      .dyna-grid {
        grid-template-columns: 1fr
      }
    }

    .dyna-chip {
      background: #FFFFFF;
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 13px 14px
    }

    .dc-lbl {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: var(--blue);
      margin-bottom: 5px
    }

    .dc-t {
      font-size: 13px;
      font-weight: 700;
      color: var(--slate);
      margin-bottom: 4px
    }

    .dc-s {
      font-size: 12px;
      color: var(--slate2);
      line-height: 1.5
    }

    .dyna-ft {
      background: #F8FAFC;
      border-top: 1px solid var(--border);
      padding: 11px 22px;
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
      align-items: center
    }

    .dbadge {
      display: flex;
      align-items: center;
      gap: 5px;
      font-size: 11px;
      font-weight: 600;
      color: var(--slate2)
    }

    .dbadge::before {
      content: '✓';
      color: var(--blue);
      font-weight: 800
    }

    .rtable {
      width: 100%;
      border-collapse: collapse;
      font-size: 13px;
      margin-bottom: var(--gap)
    }

    .rtable th {
      background: #F1F5F9;
      color: var(--slate);
      padding: 10px 14px;
      text-align: left;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: .5px;
      text-transform: uppercase
    }

    .rtable th:first-child {
      border-radius: var(--r) 0 0 0
    }

    .rtable th:last-child {
      border-radius: 0 var(--r) 0 0
    }

    .rtable td {
      padding: 10px 14px;
      border-bottom: 1px solid var(--border);
      color: var(--slate2);
      vertical-align: top;
      line-height: 1.5
    }

    .rtable tr:last-child td {
      border-bottom: none
    }

    .rtable tr:hover td {
      background: #F8FAFF
    }

    .rtable code {
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px;
      background: #F1F5F9;
      padding: 2px 5px;
      border-radius: 4px;
      color: var(--slate)
    }

    .by {
      background: #DCFCE7;
      color: #15803D;
      border-radius: 4px;
      padding: 2px 7px;
      font-size: 10px;
      font-weight: 700
    }

    .bn {
      background: #FEF2F2;
      color: #B91C1C;
      border-radius: 4px;
      padding: 2px 7px;
      font-size: 10px;
      font-weight: 700
    }

    .bf {
      background: #EFF6FF;
      color: #1E40AF;
      border-radius: 4px;
      padding: 2px 7px;
      font-size: 10px;
      font-weight: 700;
      font-family: 'JetBrains Mono', monospace
    }

    .footer {
      background: #FFFFFF;
      padding: clamp(28px, 4vw, 48px) var(--px);
      display: flex;
      gap: clamp(20px, 3vw, 48px);
      flex-wrap: wrap;
      align-items: flex-start;
      margin-top: clamp(32px, 5vw, 64px);
      border-top: 1px solid var(--border)
    }

    .ft-col {
      flex: 2;
      min-width: 200px
    }

    .ft-lbl {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 14px
    }

    .ft-row {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 9px
    }

    .ft-ic {
      width: 27px;
      height: 27px;
      border-radius: 7px;
      background: #F1F5F9;
      border: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0
    }

    .ft-ic img,
    .ft-ic svg {
      width: 13px;
      height: 13px;
      object-fit: contain;
      filter: none !important;
    }

    .ft-t {
      font-size: 12px;
      font-weight: 600;
      color: var(--slate)
    }

    .ft-ta {
      flex: 1;
      min-width: 400px;
      background: #F8FAFC;
      border: 1px solid var(--border);
      border-radius: var(--r);
      padding: 16px 18px
    }

    .ftat {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--blue);
      margin-bottom: 10px
    }

    .ftar {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 4px 0;
      font-size: 12px;
      color: var(--slate2)
    }

    .ftad {
      width: 4px;
      height: 4px;
      border-radius: 50%;
      background: var(--blue);
      flex-shrink: 0
    }

    pre {
      margin: 0
    }

    /* ── MOBILE HAMBURGER BUTTON ── */
    .nav-toggle {
      display: none;
      position: fixed;
      top: 12px;
      left: 12px;
      z-index: 300;
      width: 40px;
      height: 40px;
      border-radius: 10px;
      background: var(--card);
      border: 1px solid var(--border);
      box-shadow: 0 2px 8px rgba(0, 0, 0, .12);
      cursor: pointer;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: 5px;
      padding: 10px;
      transition: background .15s;
    }

    .nav-toggle span {
      display: block;
      width: 100%;
      height: 2px;
      background: var(--slate);
      border-radius: 2px;
      transition: transform .2s, opacity .2s;
    }

    .nav-toggle.open span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }

    .nav-toggle.open span:nth-child(2) {
      opacity: 0;
    }

    .nav-toggle.open span:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }

    /* Overlay backdrop */
    .nav-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(10, 22, 40, .45);
      z-index: 198;
      backdrop-filter: blur(2px);
    }

    /* ── MOBILE BREAKPOINT ── */
    @media (max-width: 768px) {
      body {
        height: auto;
        overflow: auto;
        flex-direction: column;
      }

      /* Sidebar becomes a slide-in drawer */
      .nav {
        position: fixed;
        left: 0;
        top: 0;
        height: 100vh;
        z-index: 200;
        transform: translateX(-100%);
        transition: transform .25s cubic-bezier(.4, 0, .2, 1);
        box-shadow: none;
        width: 280px;
      }

      .nav.open {
        transform: translateX(0);
        box-shadow: 4px 0 24px rgba(0, 0, 0, .15);
      }

      .nav-overlay.visible {
        display: block;
      }

      .nav-toggle {
        display: flex;
      }

      /* Main content is full-width, not flex child */
      .main-content {
        flex: none;
        height: auto;
        overflow: visible;
        width: 100%;
        /* Push content down so hamburger doesn't overlap hero */
        padding-top: 0;
      }

      /* Hero gets top padding for hamburger */
      .hero {
        padding-top: clamp(52px, 10vw, 64px);
      }

      /* Tables: allow horizontal scroll on small screens */
      .rtable-wrap {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        margin-bottom: var(--gap);
      }

      .rtable {
        min-width: 560px;
        margin-bottom: 0;
      }

      /* Gates wrap to column */
      .gates {
        flex-direction: column;
      }

      .gate {
        border-right: none;
        border-bottom: 1px solid var(--border);
        flex-direction: row;
        text-align: left;
        gap: 12px;
        align-items: center;
      }

      .gate:last-child {
        border-bottom: none;
      }

      .garr {
        display: none;
      }

      /* Flow bar is already scrollable — just ensure it works */
      .flow-bar {
        padding: 14px 16px;
      }

      /* Reduce horizontal padding on small screens */
      :root {
        --px: 16px;
        --gap: 14px;
      }

      /* Footer stacks */
      .footer {
        flex-direction: column;
      }

      .ft-col,
      .ft-ta {
        width: 100%;
        min-width: unset;
      }

      /* Code blocks: ensure horizontal scroll */
      pre {
        font-size: 11px;
        overflow-x: auto;
      }

      /* Journey strip steps: slightly more compact */
      .j-step {
        padding: 12px 14px;
      }

      /* Dyna grid: single column */
      .dyna-grid {
        grid-template-columns: 1fr;
      }
    }

    /* Wrap rtable in a scrollable container via JS (fallback via class) */
    .rtable-wrap {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      margin-bottom: var(--gap);
    }

    .rtable-wrap .rtable {
      margin-bottom: 0;
    }

    /* ── PERSONA BADGES ── */
    .persona-bar {
      display: flex;
      gap: 8px;
      margin-bottom: 14px;
      flex-wrap: wrap;
    }

    .persona {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: .8px;
      text-transform: uppercase;
      padding: 4px 10px;
      border-radius: 20px;
      border: 1.5px solid;
    }

    .persona-dev {
      background: #EFF6FF;
      border-color: #93C5FD;
      color: #1E40AF;
    }

    .persona-ops {
      background: #F0FDF4;
      border-color: #86EFAC;
      color: #15803D;
    }

    .persona-both {
      background: #F5F3FF;
      border-color: #C4B5FD;
      color: #6D28D9;
    }

    /* ── GOVERNANCE GRID ── */
    .gov-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: var(--gap);
      margin-bottom: var(--gap);
    }

    .gov-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--r);
      padding: 16px 18px;
      position: relative;
    }

    .gov-card::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 4px;
      border-radius: var(--r) 0 0 var(--r);
    }

    .gov-card.gc-green::before {
      background: var(--green);
    }

    .gov-card.gc-blue::before {
      background: var(--blue);
    }

    .gov-card.gc-purple::before {
      background: var(--purple);
    }

    .gov-card.gc-amber::before {
      background: var(--amber);
    }

    .gov-ttl {
      font-size: 13px;
      font-weight: 700;
      color: var(--slate);
      margin-bottom: 10px;
      display: flex;
      align-items: center;
      gap: 7px;
    }

    .gov-list {
      display: flex;
      flex-direction: column;
      gap: 5px;
    }

    .gov-item {
      display: flex;
      align-items: flex-start;
      gap: 7px;
      font-size: 12.5px;
      color: var(--slate2);
      line-height: 1.4;
    }

    .gov-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      flex-shrink: 0;
      margin-top: 5px;
    }

    .gc-green .gov-dot {
      background: var(--green);
    }

    .gc-blue .gov-dot {
      background: var(--blue);
    }

    .gc-purple .gov-dot {
      background: var(--purple);
    }

    .gc-amber .gov-dot {
      background: var(--amber);
    }
  </style>
</head>

