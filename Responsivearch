            <span class="kw">limits</span><span class="punct">:</span>
              <span class="key">cpu</span><span class="punct">:</span>    <span class="str">"2000m"</span>                 <span class="cmt"># max 2 cores allowed</span>
              <span class="key">memory</span><span class="punct">:</span> <span class="str">"4Gi"</span>                  <span class="cmt"># OOMKilled if exceeded — monitor this</span></pre>
