          <div class="fl">Jenkins Build 1</div>
          <div class="fs">Hop Version Pipeline</div>
        </div>
        <div class="fa">→</div>
        <div class="fn">
          <div class="fi" style="background:#EFF6FF"><svg
              style="width:30px;height:30px;filter:invert(29%) sepia(89%) saturate(1000%) hue-rotate(190deg)"
