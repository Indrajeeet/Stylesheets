    <!-- BIG PICTURE FLOW -->
    <section class="section">
      <div class="sec-lbl">How it all fits together</div>
      <h2 class="sec-h">From code push to running pipeline</h2>
      <p class="sec-sub">Dev push code. Jenkins builds an image. OpenShift runs it as a short-lived throwaway pod.
        Dynatrace watches everything. That's the whole loop.</p>
      <div class="flow-bar">
        <div class="fn">
          <div class="fi" style="background:#EFF6FF"><svg
              style="width:30px;height:30px;filter:invert(29%) sepia(89%) saturate(1800%) hue-rotate(205deg)"
