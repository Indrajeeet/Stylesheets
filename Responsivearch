  <script>
    // ── Intersection observer for active nav links ──
    const links = document.querySelectorAll('.nl');
    const secs = document.querySelectorAll('section[id],header[id]');

    // On mobile, main-content is not the scroll root — use document
    function getScrollRoot() {
      return window.innerWidth <= 768 ? null : document.querySelector('.main-content');
    }

    let obs = null;
    function initObserver() {
      if (obs) obs.disconnect();
      obs = new IntersectionObserver(e => {
        e.forEach(en => {
          if (en.isIntersecting) {
            links.forEach(l => l.classList.remove('active'));
            const a = document.querySelector(`.nl[href="#${en.target.id}"]`);
            if (a) a.classList.add('active');
          }
        });
      }, { root: getScrollRoot(), rootMargin: '-50px 0px -70% 0px' });
      secs.forEach(s => obs.observe(s));
    }
    initObserver();
    window.addEventListener('resize', initObserver);

    // ── Hamburger nav toggle ──
    const navToggle = document.getElementById('navToggle');
    const navOverlay = document.getElementById('navOverlay');
    const mainNav = document.getElementById('mainNav');

    function openNav() {
      mainNav.classList.add('open');
      navToggle.classList.add('open');
      navOverlay.classList.add('visible');
      navToggle.setAttribute('aria-label', 'Close navigation');
      document.body.style.overflow = 'hidden';
    }

    function closeNav() {
      mainNav.classList.remove('open');
      navToggle.classList.remove('open');
      navOverlay.classList.remove('visible');
      navToggle.setAttribute('aria-label', 'Open navigation');
      document.body.style.overflow = '';
    }

    navToggle.addEventListener('click', () => {
      mainNav.classList.contains('open') ? closeNav() : openNav();
    });

    navOverlay.addEventListener('click', closeNav);

    // Close nav when a link is clicked on mobile
    links.forEach(l => l.addEventListener('click', () => {
      if (window.innerWidth <= 768) closeNav();
    }));

    // ── Wrap tables in scrollable containers ──
    document.querySelectorAll('.rtable').forEach(tbl => {
      if (!tbl.parentElement.classList.contains('rtable-wrap')) {
        const wrap = document.createElement('div');
        wrap.className = 'rtable-wrap';
        tbl.parentNode.insertBefore(wrap, tbl);
        wrap.appendChild(tbl);
      }
    });
  </script>
