      <div style="display:flex; flex-direction:column; gap:var(--gap); margin-bottom:var(--gap)">
        <div class="fc full">
          <details>
            <summary class="fc-hd">
              <div class="fc-icon" style="background:#FEF3E2"><svg
                  style="width:19px;height:19px;filter:invert(38%) sepia(60%) saturate(700%) hue-rotate(355deg)"
                  viewBox="0 0 24 24">
