                    --build-arg HOP_VERSION=${params.HOP_VERSION} \\
                    --build-arg HOP_DOWNLOAD_URL=${env.HOP_DOWNLOAD} \\
                    -t ${env.REGISTRY}/${env.IMAGE_NAME}:${env.IMAGE_TAG} \\
