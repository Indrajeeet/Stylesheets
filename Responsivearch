          <span class="key">secret</span><span class="punct">:</span>
            <span class="kw">secretName</span><span class="punct">:</span> hop-secret-files       <span class="cmt"># PGP keys, SSH keys, .jks files</span>

        <span class="punct">-</span> <span class="kw">name</span><span class="punct">:</span> tmp-work
          <span class="key">emptyDir</span><span class="punct">:</span> <span class="punct">{}</span>                         <span class="cmt"># scratch space — gone when pod exits</span>

      <span class="key">containers</span><span class="punct">:</span>
        <span class="punct">-</span> <span class="kw">name</span><span class="punct">:</span> hop-runner

          <span class="cmt"># THE IMAGE — pinned to a version from Artifactory ───────────────────</span>
          <span class="key">image</span><span class="punct">:</span> <span class="str">artifactory.myorg.com/hop/customer-data-load:1.0.0</span>

