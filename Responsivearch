            </summary>
            <div class="cw" style="border:none;border-radius:0;border-top:1px solid var(--border)">
              <pre><span class="kw">apiVersion</span><span class="punct">:</span> batch/v1
<span class="kw">kind</span><span class="punct">:</span> Job
<span class="kw">metadata</span><span class="punct">:</span>
  <span class="kw">name</span><span class="punct">:</span> customer-data-load-<span class="val">20240315-001</span>    <span class="cmt"># unique name per run</span>
