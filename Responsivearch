        <span class="cmd">string</span>(<span class="key">name</span>: <span class="str">'IMAGE_REVISION'</span>,  <span class="key">defaultValue</span>: <span class="str">'v1'</span>,     <span class="key">description</span>: <span class="str">'Image revision (v1, v2, etc.)'</span>)
