<span class="cmd">COPY</span> <span class="arg">drivers/oracle/*.jar    /opt/hop/lib/jdbc/</span>
<span class="cmd">COPY</span> <span class="arg">drivers/postgres/*.jar  /opt/hop/lib/jdbc/</span>
<span class="cmd">COPY</span> <span class="arg">drivers/mssql/*.jar     /opt/hop/lib/jdbc/</span>

