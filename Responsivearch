<span class="cmt"># Hop Version Build — produces hop-base image</span>
<span class="cmt"># Triggered manually when platform team decides to adopt a new Hop release</span>

<span class="cmd">pipeline</span> {
    <span class="key">agent</span> any

    <span class="key">parameters</span> {
