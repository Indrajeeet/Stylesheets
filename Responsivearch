<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>FINAL CI/CD DESIGN – Apache Hop on ROSA</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
/* ── RESET ── */
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#eef2f7;--card:#fff;
  --blue:#1e5cb3;--blue-dk:#0f2d6b;--blue-lt:#dbeafa;--blue-bd:#8ab0e0;
  --green:#1a7c3e;--green-dk:#155724;--green-lt:#d4edda;--green-bd:#7dbc8f;
  --teal:#0e7c86;--teal-dk:#0d5c63;--teal-lt:#c8e8e8;--teal-bd:#5db8c0;
  --purple:#6f3aab;--purple-dk:#4a1d7a;--purple-lt:#e8d8f8;--purple-bd:#b07de0;
  --amber:#d97706;--amber-lt:#fff8e1;--amber-bd:#ffd966;
  --red:#c0392b;--red-lt:#fdecea;--red-bd:#f5a9a3;
  --slate:#1e293b;--muted:#64748b;--border:#dee2e6;
  --code:#0f172a;
  --r:8px;--gap:10px;--pad:10px;
}
html,body{width:100%}
body{font-family:'Inter',system-ui,sans-serif;background:var(--bg);color:var(--slate);font-size:12px;line-height:1.45;padding:var(--gap)}

/* ── PAGE HEADER ── */
.page-hdr{text-align:center;background:linear-gradient(90deg,var(--blue-lt),#fff,var(--blue-lt));border:2px solid var(--blue-bd);border-radius:var(--r);padding:10px 16px;margin-bottom:var(--gap)}
.page-hdr h1{font-size:clamp(14px,2vw,22px);font-weight:900;color:var(--blue-dk)}
.page-hdr p{font-size:clamp(9px,1vw,12px);color:var(--muted);margin-top:3px}

/* ── SECTION WRAPPER ── */
.sec{border-radius:var(--r);padding:var(--pad);display:flex;flex-direction:column;gap:7px}
.sec-hdr{font-size:clamp(9px,1vw,11px);font-weight:900;text-transform:uppercase;letter-spacing:.5px;color:#fff;border-radius:6px;padding:4px 10px;text-align:center;display:flex;align-items:center;justify-content:center;gap:6px;flex-shrink:0}

/* ── SECTION COLOURS ── */
.sec-blue  {background:var(--blue-lt); border:2px solid var(--blue-bd)}
.sec-blue  .sec-hdr{background:var(--blue-dk)}
.sec-green {background:var(--green-lt);border:2px solid var(--green-bd)}
.sec-green .sec-hdr{background:var(--green)}
.sec-teal  {background:var(--teal-lt); border:2px solid var(--teal-bd)}
.sec-teal  .sec-hdr{background:var(--teal)}
.sec-purple{background:var(--purple-lt);border:2px solid var(--purple-bd)}
.sec-purple .sec-hdr{background:var(--purple)}
.sec-indigo{background:#e0e8ff;border:2px solid #7b96e0}
.sec-indigo .sec-hdr{background:#2d3a8c}

/* ── MASTER LAYOUT ── */
.row1{display:grid;grid-template-columns:minmax(0,15%) 1fr minmax(0,17%) minmax(0,17%);gap:var(--gap);margin-bottom:var(--gap)}
.row2{display:grid;grid-template-columns:1fr minmax(0,21%);gap:var(--gap);margin-bottom:var(--gap)}
.row3{margin-bottom:var(--gap)}
.row4{display:grid;grid-template-columns:1fr 1fr;gap:var(--gap)}

/* ── GENERIC CARD ── */
.card{background:var(--card);border:1.5px solid var(--border);border-radius:var(--r);padding:8px}
.card-title{font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:.4px;color:var(--muted);margin-bottom:5px;padding-bottom:4px;border-bottom:1px solid var(--border)}

/* ── BULLETS ── */
.bul{list-style:none;display:flex;flex-direction:column;gap:3px}
.bul li{padding-left:11px;position:relative;font-size:10.5px;color:#334155;line-height:1.4}
.bul li::before{content:'•';position:absolute;left:0}
.bul.blue li::before{color:var(--blue)}
.bul.green li::before{color:var(--green)}
.bul.teal li::before{color:var(--teal)}
.bul.purple li::before{color:var(--purple)}
.bul.amber li::before{color:var(--amber)}

/* ── CODE ── */
.code{background:var(--code);border-radius:6px;padding:8px 10px;font-family:'JetBrains Mono',monospace;font-size:9.5px;line-height:1.75}
.kw{color:#f472b6;font-weight:600}.val{color:#a3e635}.str{color:#f87171}.arg{color:#e2e8f0}.key{color:#38bdf8}

/* ── ARROWS ── */
.arr{text-align:center;font-size:14px;font-weight:700;line-height:1;flex-shrink:0}

/* ══════════ S1 ══════════ */
.s1-dev{display:flex;align-items:center;gap:8px;padding:3px 0}
.bb-box{background:var(--card);border:1.5px solid var(--blue-bd);border-radius:var(--r);padding:7px;display:flex;align-items:center;gap:8px}
.bb-logo{width:26px;height:26px;background:#2684ff;border-radius:5px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.ftree{font-family:'JetBrains Mono',monospace;font-size:9.5px;line-height:1.85;color:#475569}
.ftree .fd{color:var(--blue-dk);font-weight:600}.ftree .fg{color:var(--green);font-weight:600}.ftree .fb{color:var(--blue)}
.yaml-grid{display:grid;grid-template-columns:auto 1fr;gap:1px 5px;font-family:'JetBrains Mono',monospace;font-size:9px;line-height:1.8}
.yaml-k{color:#2684ff}.yaml-v{color:var(--slate)}.yaml-g{color:var(--green);font-weight:600}

/* ══════════ S2 ══════════ */
.steps-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:7px}
.step{background:var(--card);border:1.5px solid var(--blue-bd);border-radius:var(--r);padding:8px;display:flex;flex-direction:column;gap:4px}
.step-top{display:flex;align-items:center;gap:5px}
.step-num{width:20px;height:20px;background:var(--blue-dk);color:#fff;border-radius:50%;font-size:10px;font-weight:800;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.step-ttl{font-size:10px;font-weight:700;color:var(--blue-dk);line-height:1.3}
.step-ico{text-align:center;padding:3px 0}
.df-box{background:var(--card);border:1.5px solid var(--blue-bd);border-radius:var(--r);padding:8px}
.df-title{font-size:10px;font-weight:800;text-transform:uppercase;color:var(--blue-dk);letter-spacing:.4px;text-align:center;margin-bottom:5px}

/* ══════════ S3 ══════════ */
.repo-grp{background:var(--card);border:1.5px solid var(--green-bd);border-radius:var(--r);padding:7px}
.repo-grp-title{font-size:10px;font-weight:700;color:var(--green-dk);text-align:center;border-bottom:1px solid var(--green-lt);padding-bottom:3px;margin-bottom:5px}
.repo-item{font-family:'JetBrains Mono',monospace;font-size:9.5px;color:#1e293b;padding:1px 0}
.repo-item.ok{color:var(--green);font-weight:700}.repo-item.lt{color:var(--blue);font-weight:600}
.art-checks{background:#f0fdf4;border:1px solid var(--green-bd);border-radius:6px;padding:7px;display:flex;flex-direction:column;gap:3px}
.art-chk{display:flex;align-items:center;gap:5px;font-size:10px;color:var(--green-dk)}

/* ══════════ S4 ══════════ */
.pstage{border-radius:7px;padding:6px 8px}
.pstage.dev{background:var(--blue-lt);border:1.5px solid var(--blue-bd)}
.pstage.gate{background:var(--amber-lt);border:1.5px solid var(--amber-bd);display:flex;align-items:center;gap:7px}
.pstage.qa,.pstage.uat{background:#f5f5f5;border:1.5px solid #ccc}
.pstage.prod{background:var(--red-lt);border:1.5px solid var(--red-bd)}
.pstage-lbl{font-size:11px;font-weight:800;display:flex;align-items:center;gap:5px}
.gate-ico{width:26px;height:26px;border-radius:50%;background:var(--purple-lt);border:1.5px solid var(--purple-bd);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.gate-lbl{font-size:10px;font-weight:700;color:var(--purple-dk)}
.gate-sub{font-size:9.5px;color:var(--muted)}

/* ══════════ S5 ══════════ */
.runtime-cols{display:grid;grid-template-columns:1fr 1fr 1.3fr 1fr;gap:var(--gap)}
.cfg-hdr{font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:.3px;padding:3px 8px;border-radius:5px;text-align:center;margin-bottom:4px}
.cfg-hdr.cm{background:#d1fae5;color:var(--green-dk)}.cfg-hdr.sec{background:var(--red-lt);color:var(--red)}
.cfg-sub{font-size:9.5px;color:var(--muted);font-style:italic;text-align:center;margin-bottom:4px}
.cfg-ex{font-size:9.5px;font-weight:700;color:var(--teal);margin:4px 0 2px}
.how-step{display:flex;align-items:flex-start;gap:6px;margin-bottom:5px}
.how-num{width:18px;height:18px;border-radius:50%;background:var(--blue);color:#fff;font-size:9px;font-weight:800;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px}
.how-txt{font-size:10px;color:#1e293b;line-height:1.5}
.how-txt strong{color:var(--blue-dk)}
.mount-bar{background:#d1f5f7;border:1.5px solid var(--teal-bd);border-radius:7px;padding:6px 12px;display:flex;align-items:center;flex-wrap:wrap;gap:8px;margin-top:6px}
.mount-chip{font-family:'JetBrains Mono',monospace;font-size:9.5px;background:#fff;border:1px solid var(--teal-bd);border-radius:4px;padding:1px 6px;color:var(--teal-dk)}

/* ══════════ S6 ══════════ */
.dep-flow{display:flex;align-items:center;justify-content:center;gap:10px;margin-bottom:8px}
.dep-node{background:var(--card);border:1.5px solid var(--blue-bd);border-radius:var(--r);padding:8px 12px;text-align:center}
.dep-node-lbl{font-size:10px;font-weight:700;color:var(--blue-dk);margin-top:3px}
.uses-box{background:var(--blue-lt);border:1px solid var(--blue-bd);border-radius:7px;padding:7px;margin-bottom:7px}
.uses-ttl{font-size:10px;font-weight:700;color:var(--blue-dk);margin-bottom:4px}
.os-res{display:flex;justify-content:space-around;flex-wrap:wrap;gap:6px;margin-top:4px}
.os-item{display:flex;flex-direction:column;align-items:center;gap:3px}
.os-lbl{font-size:9.5px;font-weight:600;color:var(--blue-dk);text-align:center}

/* ══════════ S7 ══════════ */
.gov-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:var(--gap)}
.gov-card{background:var(--card);border:1.5px solid var(--border);border-radius:var(--r);padding:8px}
.gov-ttl{font-size:11px;font-weight:700;color:var(--slate);display:flex;align-items:center;gap:6px;margin-bottom:5px}

/* ══════════ ROW4 ══════════ */
.info-box{background:var(--card);border:1.5px solid var(--border);border-radius:var(--r);padding:10px}
.info-ttl{font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:.4px;color:var(--slate);margin-bottom:7px;padding-bottom:5px;border-bottom:1px solid var(--border)}
.leg-item{display:flex;align-items:center;gap:10px;font-size:11px;color:var(--slate);margin-bottom:5px}
.leg-line{width:36px;height:2.5px;border-radius:2px;flex-shrink:0}
.leg-dash{width:36px;height:0;border-top:2.5px dashed;flex-shrink:0}
.leg-rect{width:20px;height:12px;border:2px solid;border-radius:3px;flex-shrink:0}
.ben-item{display:flex;align-items:flex-start;gap:7px;font-size:11px;color:var(--slate);margin-bottom:5px;line-height:1.4}
.ben-chk{color:var(--green);font-size:13px;flex-shrink:0}

/* ══════════ RESPONSIVE ══════════ */
@media(max-width:1199px){
  .row1{grid-template-columns:1fr 1fr}
  .row2{grid-template-columns:1fr}
  .runtime-cols{grid-template-columns:1fr 1fr}
  .steps-grid{grid-template-columns:repeat(3,1fr)}
  .gov-grid{grid-template-columns:repeat(2,1fr)}
}
@media(max-width:767px){
  .row1{grid-template-columns:1fr}
  .row4{grid-template-columns:1fr}
  .runtime-cols{grid-template-columns:1fr}
  .steps-grid{grid-template-columns:1fr 1fr}
  .gov-grid{grid-template-columns:1fr 1fr}
}
@media(max-width:480px){
  .steps-grid{grid-template-columns:1fr}
  .gov-grid{grid-template-columns:1fr}
  .row4{grid-template-columns:1fr}
}
</style>
</head>
<body>

<!-- PAGE HEADER -->
<div class="page-hdr">
  <h1>FINAL CI/CD DESIGN – Apache Hop on ROSA (OpenShift)</h1>
  <p>Jenkins &nbsp;+&nbsp; Bitbucket &nbsp;+&nbsp; Artifactory &nbsp;+&nbsp; Approval Workflow &nbsp;+&nbsp; ConfigMaps/Secrets &nbsp;+&nbsp; Immutable Images</p>
</div>

<!-- ══════ ROW 1 ══════ -->
<div class="row1">

  <!-- S1: SOURCE -->
  <div class="sec sec-blue">
    <div class="sec-hdr">1. Source (Developer)</div>

    <div class="s1-dev">
      <div style="width:34px;height:34px;background:var(--blue-dk);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </div>
      <div>
        <div style="font-weight:700;font-size:12px;color:var(--blue-dk)">Developer</div>
        <svg width="28" height="16" viewBox="0 0 32 20" style="margin-top:2px"><rect x="2" y="2" width="28" height="16" rx="3" fill="none" stroke="#0f2d6b" stroke-width="1.5"/><polyline points="8,14 12,10 8,6" fill="none" stroke="#1e5cb3" stroke-width="1.5" stroke-linecap="round"/><line x1="14" y1="14" x2="20" y2="14" stroke="#1e5cb3" stroke-width="1.5" stroke-linecap="round"/></svg>
      </div>
    </div>

    <ul class="bul blue"><li>Create/Update Hop Pipelines &amp; Workflows</li><li>Update app.yaml (metadata only)</li><li>Commit &amp; Push</li></ul>

    <div class="arr" style="color:var(--blue)">↓</div>

    <div class="bb-box">
      <div class="bb-logo"><svg width="15" height="15" viewBox="0 0 20 20" fill="none"><path d="M1.08 1.6a.5.5 0 0 0-.5.58l2.15 13.06a.67.67 0 0 0 .67.57H16.8a.5.5 0 0 0 .5-.42l2.16-13.19a.5.5 0 0 0-.5-.6H1.08zm9.22 9.2H9.8l-.88-4.6h4.98l-.88 4.6h-3.7z" fill="#fff"/></svg></div>
      <div><div style="font-size:11px;font-weight:700;color:var(--blue-dk)">Bitbucket</div><div style="font-size:9.5px;color:var(--muted)">Git Repository</div></div>
    </div>

    <div class="arr" style="color:var(--blue)">↓</div>

    <div class="card">
      <div class="card-title">Repository Structure</div>
      <div class="ftree">
        <div class="fd">📁 my-hop-project/</div>
        <div class="fd">&nbsp;├── 📁 hop/</div>
        <div>&nbsp;│&nbsp;&nbsp;├── pipelines/</div>
        <div>&nbsp;│&nbsp;&nbsp;├── workflows/</div>
        <div>&nbsp;│&nbsp;&nbsp;└── scripts/</div>
        <div class="fd">&nbsp;├── 📁 config/base/</div>
        <div>&nbsp;│&nbsp;&nbsp;└── project-config.json</div>
        <div class="fg">&nbsp;├── 📄 app.yaml</div>
        <div class="fb">&nbsp;└── 📄 README.md</div>
      </div>
    </div>

    <div class="card">
      <div class="card-title">app.yaml (Example)</div>
      <div class="yaml-grid">
        <span class="yaml-k">appName:</span><span class="yaml-v">customer-load</span>
        <span class="yaml-k">team:</span><span class="yaml-v">finance</span>
        <span class="yaml-k">runtime:</span><span class="yaml-g">hop-runtime:2.15-v3</span>
        <span class="yaml-k">cpu:</span><span class="yaml-v">"500m"</span>
        <span class="yaml-k">memory:</span><span class="yaml-v">"1Gi"</span>
        <span class="yaml-k">replicas:</span><span class="yaml-v">1</span>
        <span class="yaml-k">route:</span><span class="yaml-v">false</span>
        <span class="yaml-k">schedule:</span><span class="yaml-v">controlm</span>
        <span class="yaml-k">javaOpts:</span><span class="yaml-v">-Xms512m -Xmx1024m</span>
      </div>
    </div>
  </div>

  <!-- S2: CI/CD PIPELINE -->
  <div class="sec sec-blue">
    <div class="sec-hdr">
      <svg width="15" height="15" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" fill="#d33f3f"/><text x="12" y="16" text-anchor="middle" font-size="10" font-weight="800" fill="#fff">J</text></svg>
      2. CI/CD Pipeline (Jenkins)
    </div>

    <div class="steps-grid">
      <div class="step">
        <div class="step-top"><span class="step-num">1</span><span class="step-ttl">Checkout &amp; Validate</span></div>
        <div class="step-ico"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#1e5cb3" stroke-width="1.5"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg></div>
        <ul class="bul blue"><li>Clone from Bitbucket</li><li>Validate app.yaml</li><li>Validate structure</li><li>Read metadata</li></ul>
      </div>
      <div class="step">
        <div class="step-top"><span class="step-num">2</span><span class="step-ttl">Build App Image (Dynamic)</span></div>
        <div class="step-ico"><svg width="26" height="26" viewBox="0 0 24 24" fill="#2496ed"><path d="M13.98 11.08a1.86 1.86 0 0 0 0 3.72h2.12a.19.19 0 0 0 .19-.19V9.06a.19.19 0 0 0-.19-.19h-2.12a.19.19 0 0 0-.19.19v2.02z"/><path d="M23.76 9.89c-.07-.05-.67-.51-1.95-.51a5.2 5.2 0 0 0-1.01.09c-.25-1.7-1.65-2.53-1.72-2.57l-.34-.2-.23.33a4.47 4.47 0 0 0-.61 1.43c-.23.97-.09 1.88.4 2.66-.59.33-1.55.41-1.74.42H.75a.75.75 0 0 0-.75.75c0 1.44.22 2.83.69 4.06.54 1.43 1.35 2.48 2.41 3.12 1.18.72 3.1 1.14 5.28 1.14a13.5 13.5 0 0 0 2.93-.27 12.3 12.3 0 0 0 3.82-1.39 9.45 9.45 0 0 0 2.61-2.14c1.25-1.42 2-3 2.55-4.4h.22c1.37 0 2.22-.55 2.68-1.01.31-.29.55-.65.71-1.04l.1-.29-.22-.18z"/></svg></div>
        <ul class="bul blue"><li>Generate Dockerfile using approved runtime image</li><li>Copy hop/ &amp; scripts/</li><li>Build application image</li></ul>
      </div>
      <div class="step">
        <div class="step-top"><span class="step-num">3</span><span class="step-ttl">Scan &amp; Push Image</span></div>
        <div class="step-ico"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#1a7c3e" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg></div>
        <ul class="bul green"><li>Security Scan (Trivy/Xray)</li><li>Push image to Artifactory (apps repo)</li></ul>
      </div>
      <div class="step">
        <div class="step-top"><span class="step-num">4</span><span class="step-ttl">Deploy to DEV (Auto)</span></div>
        <div class="step-ico"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#e6860a" stroke-width="1.5"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg></div>
        <ul class="bul blue"><li>Deploy to DEV namespace</li><li>Create/Update ConfigMaps, Secrets</li><li>Smoke tests</li></ul>
      </div>
      <div class="step">
        <div class="step-top"><span class="step-num">5</span><span class="step-ttl">Record &amp; Notify</span></div>
        <div class="step-ico"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="1.5"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg></div>
        <ul class="bul amber"><li>Record build details</li><li>Notify teams (Slack/Email)</li></ul>
      </div>
    </div>

    <div class="df-box">
      <div class="df-title">Dynamic Dockerfile (Generated by Jenkins)</div>
      <div class="code">
        <span class="kw">FROM</span> <span class="arg">artifactory.company.com/docker/hop-runtime:2.15-v3</span><br>
        <span class="kw">COPY</span> <span class="arg">hop/ /app/hop/</span><br>
        <span class="kw">COPY</span> <span class="arg">scripts/ /app/scripts/</span><br>
        <span class="kw">COPY</span> <span class="arg">config/base/project-config.json /app/config/base/</span><br>
        <span class="kw">COPY</span> <span class="arg">deploy/entrypoint.sh /entrypoint.sh</span><br>
        <span class="kw">RUN</span>  <span class="arg">chmod +x /entrypoint.sh</span><br>
        <span class="kw">ENTRYPOINT</span> <span class="val">["/entrypoint.sh"]</span>
      </div>
    </div>
  </div>

  <!-- S3: ARTIFACTORY -->
  <div class="sec sec-green">
    <div class="sec-hdr">
