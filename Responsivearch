                </svg></div>
              <div>
                <div class="fc-fn">Jenkinsfile — standard pipeline</div>
                <div class="fc-tag">Your project's entrypoint for CI/CD. It calls the shared library.</div>
              </div>
              <div class="view-code-btn">Toggle Code</div>
            </summary>
            <div class="cw" style="border:none;border-radius:0;border-top:1px solid var(--border)">
              <pre><span class="cmt">#!/usr/bin/env groovy</span>
<span class="cmt"># Uses the central organization shared library</span>
<span class="key">@Library</span>(<span class="str">'hop-shared-library@v1'</span>) _

<span class="cmt"># The shared library abstracts all the complexity of Docker builds,</span>
<span class="cmt"># OpenShift deployments, and Artifactory interactions.</span>
<span class="cmd">hopStandardPipeline</span> {
    <span class="key">appName</span> = <span class="str">'customer-data-load'</span>
    <span class="key">teamName</span> = <span class="str">'finance-data'</span>
    <span class="key">deployTo</span> = [<span class="str">'DEV'</span>, <span class="str">'QA'</span>, <span class="str">'UAT'</span>, <span class="str">'PROD'</span>]
}</pre>
            </div>
          </details>
        </div>
        <div class="fc full">
          <details>
            <summary class="fc-hd">
              <div class="fc-icon" style="background:#FEF3E2"><svg
                  style="width:19px;height:19px;filter:invert(38%) sepia(60%) saturate(700%) hue-rotate(355deg)"
                  viewBox="0 0 24 24">
                  <use href="#jenkins" />
                </svg></div>
              <div>
                <div class="fc-fn">Jenkins Helper (vars/hopStandardPipeline.groovy)</div>
                <div class="fc-tag">Maintained by platform team. Applies the standard to all projects.</div>
              </div>
              <div class="view-code-btn">Toggle Code</div>
            </summary>
            <div class="cw" style="border:none;border-radius:0;border-top:1px solid var(--border)">
              <pre><span class="cmt"># This code lives in the central Jenkins shared library repo</span>
<span class="cmd">def</span> <span class="kw">call</span>(Map config) {
    <span class="cmd">pipeline</span> {
        <span class="key">agent</span> any
        <span class="key">stages</span> {
            <span class="key">stage</span>(<span class="str">'Read app.yaml'</span>) {
                <span class="key">steps</span> {
                    <span class="cmd">script</span> {
                        <span class="key">env</span>.APP_CONFIG = readYaml <span class="key">file</span>: <span class="str">'app.yaml'</span>
                    }
                }
            }
            <span class="key">stage</span>(<span class="str">'Build Image'</span>) {
                <span class="key">steps</span> {
                    <span class="cmd">script</span> {
                        <span class="cmt"># Tag with git SHA for full traceability — never use BUILD_ID (not stable)</span>
                        <span class="key">env</span>.GIT_SHA = <span class="cmd">sh</span>(script: <span class="str">'git rev-parse --short HEAD'</span>, returnStdout: true).trim()
                        <span class="key">env</span>.IMAGE_TAG = <span class="str">"${env.APP_CONFIG.version}-${env.GIT_SHA}"</span>  <span class="cmt"># e.g. 1.0.0-abc1234</span>
                    }
                    <span class="cmd">sh</span> <span class="str">"docker build -t artifactory.myorg.com/hop/${config.appName}:${env.IMAGE_TAG} ."</span>
                }
            }
            <span class="key">stage</span>(<span class="str">'Push to Artifactory'</span>) {
                <span class="key">steps</span> {
                    <span class="cmd">sh</span> <span class="str">"docker push artifactory.myorg.com/hop/${config.appName}:${env.IMAGE_TAG}"</span>
                }
            }
            <span class="key">stage</span>(<span class="str">'Deploy to DEV'</span>) {
                <span class="key">when</span> { <span class="key">expression</span> { config.deployTo.contains(<span class="str">'DEV'</span>) } }
                <span class="key">steps</span> {
                    <span class="cmt"># Substitute the image tag into deployment.yaml before applying</span>
                    <span class="cmt"># IMAGE_TAG placeholder in deployment.yaml gets replaced here</span>
                    <span class="cmd">sh</span> <span class="str">"""
                        sed -i 's|IMAGE_TAG_PLACEHOLDER|${env.IMAGE_TAG}|g' k8s/dev/deployment.yaml
                        oc apply -f k8s/dev/ -n hop-dev
                    """</span>
                }
            }
            <span class="key">stage</span>(<span class="str">'Smoke Test (DEV)'</span>) {
                <span class="key">steps</span> {
                    <span class="cmt"># Wait for the Job pod to complete, then verify exit code</span>
                    <span class="cmd">sh</span> <span class="str">"oc wait --for=condition=Complete job/hop-${config.appName} -n hop-dev --timeout=300s"</span>
                }
            }
            <span class="key">stage</span>(<span class="str">'Notify'</span>) {
                <span class="key">steps</span> {
                    <span class="cmt"># Notify team on success — shared library reads notify: from app.yaml</span>
                    <span class="cmd">script</span> {
                        <span class="key">emailext</span>(
                            <span class="key">to</span>: <span class="key">env</span>.APP_CONFIG.notify,
                            <span class="key">subject</span>: <span class="str">"✓ ${config.appName} ${env.IMAGE_TAG} deployed to DEV"</span>,
                            <span class="key">body</span>: <span class="str">"Image: ${env.IMAGE_TAG}\nGit SHA: ${env.GIT_SHA}\nStatus: Success"</span>
                        )
                    }
                }
            }
            <span class="cmt"># Additional stages for QA, UAT, PROD — same sed + oc apply pattern</span>
            <span class="cmt"># Same IMAGE_TAG promoted unchanged — no rebuild at any stage</span>
        }
    }
}</pre>
            </div>
